@using API_Arch_DataAccessLayer.Interphases.Areas.Foundation
@inject IDbLocalizer L

<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Architecture | @ViewBag.Title </title>

    <link rel="icon" type="image/png" href="~/images/Logos/Logo_Architecture.jpg" sizes="32x32" />
    <link rel="icon" type="image/png" href="~/images/Logos/Logo_Architecture.jpg" sizes="16x16" />

    <link href="~/css/CustomStyles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
    <link href="~/css/font-awesome-animation.min.css" rel="stylesheet" />
    <link href="~/css/adminlte.min.css" rel="stylesheet" />
    <link href="~/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" />
    <link rel="stylesheet"
          href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap4.min.css" />
    
</head>

<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">
    <!-- Site wrapper -->
    <div class="wrapper">

        @Html.Partial("_TopBar")
        @await Component.InvokeAsync("SidebarMenu")

        <div class="content-wrapper">
            

            @* <div class="top-container">
                <div class="marquee-text">
                    <i class="fa-solid fa-envelope"></i> We are working on some new features in ARCHITECTURE stay tuned.
                </div>
            </div> *@
            @RenderBody()
        </div>

        <footer class="main-footer">
            
            <div class="float-right d-none d-sm-block">
                <a href="https://twitter.com/"><i class="fa-brands fa-x-twitter faa-pulse animated" style="color:white" aria-hidden="true"></i></a>
                <a href="https://www.facebook.com/"><i class="fa-brands fa-facebook faa-pulse animated" style="color:white" aria-hidden="true"></i></a>
            </div>
            Copyright &copy; 2024-2025 <a href="#" style="color:#fff;">ARCHITECTURE</a>
        </footer>
        @* <div id="divAlert" class="container-fluid">
            @Html.Partial("_MessageBox")
        </div> *@
        <div class="modal fade" id="confirmModal" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirmation</h5>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <p id="confirmMessage">Are you sure?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="confirmYes" class="btn btn-success">Yes</button>
                        <button type="button" class="btn btn-danger" data-dismiss="modal">No</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>


    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/adminlte.min.js"></script>
    <script src="~/js/common.js"></script>

    @RenderSection("Scripts", required: false)
    <script>
        $(function () {
            $('[data-widget="pushmenu"]').PushMenu();
        });
    </script>

    <script>
        $(document).ready(function () {
            // Toggle sidebar visibility on click of the "bars" icon
            $('[data-widget="pushmenu"]').on('click', function () {
                // Toggle the sidebar menu
                $('body').toggleClass('sidebar-open');
            });

            // Set up a global AJAX error handler to handle the 401
            $.ajaxSetup({
                "statusCode": {
                    401: function () {
                        debugger;
                        // Redirect to the login page.
                        location.href = "@Url.Action("Login", "Authentication", new { area = "Accounts" })";
                    }
                }
            });

        });

                function showConfirm(message, yesCallback) {
            $('#confirmMessage').text(message);
            $('#confirmModal').modal('show');

            $('#confirmYes').off('click').on('click', function () {
                $('#confirmModal').modal('hide');
                yesCallback(true);
            });
        }
    </script>
    @await Component.InvokeAsync("Notyf")
</body>

</html>