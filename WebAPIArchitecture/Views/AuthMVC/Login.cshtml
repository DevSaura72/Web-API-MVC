@model API_Arch_ViewModel.MVC_ViewModesl.Areas.Auth.LoginViewModel
<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/webroot/css/login.css" rel="stylesheet" />
</head>

<body>
    <form>
    </form>
    <div class="container-fluid vh-100">
        <div class="row h-100">

            <div class="col-md-4 col-lg-3 login-left d-flex flex-column justify-content-center">
                <h2 class="mb-4">Login</h2>

                @using (Html.BeginForm("Login", "AuthMVC", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">Username</label>
                        @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Login</button>
                }

            </div>

            <div class="col-md-8 col-lg-9 login-right d-none d-md-block">
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
